<UserControl x:Class="CatoriUCLibrary.Views.RobotArm.RobotArmSegmentontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="140" Background="Transparent"
             Height="40" MouseUp="UserControl_MouseUp"
             MouseDown="UserControl_MouseDown"
             RenderTransformOrigin="0,0.5">

    <UserControl.RenderTransform>
        <RotateTransform x:Name="SegmentRotate" Angle="-90"/>
    </UserControl.RenderTransform>

    <Image x:Name="SegmentImage"
           Width="140"
           Height="40"
           Stretch="Fill"
           Source="/Images/robotArmLongBlue.png"/>
</UserControl>