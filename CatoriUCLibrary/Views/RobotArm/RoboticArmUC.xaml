                    Canvas.Left="0"
                    Canvas.Top="0"
                    Width="80"
                    Height="80"
                    />-->
            <Label x:Name="MessageLabel" Content="" Canvas.Left="20" Canvas.Top="590"/>
        </Canvas>
    </Viewbox>
</UserControl>
