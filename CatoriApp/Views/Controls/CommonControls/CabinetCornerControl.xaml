<UserControl x:Class="CatoriApp.Views.Controls.CommonControls.CabinetCornerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Views.Controls"
             mc:Ignorable="d" Width="15" MouseEnter="UserControl_MouseEnter" MouseLeave="UserControl_MouseLeave"
             MouseUp="UserControl_MouseUp"
             d:DesignHeight="15" d:DesignWidth="15">
    <Canvas MouseEnter="Canvas_MouseEnter" MouseLeave="Canvas_MouseLeave" MouseUp="Canvas_MouseUp" >
        <Image x:Name="CabinetCornerImage"  
                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Canvas.Left="0" Canvas.Top="0" Source="/Images/CabinetCorner.png" />
    </Canvas>
</UserControl>


