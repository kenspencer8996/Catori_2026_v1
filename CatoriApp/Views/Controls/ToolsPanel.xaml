<UserControl x:Class="CatoriApp.Views.Controls.ToolsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="190" MouseLeave="UserControl_MouseLeave">
    <Border Padding="8"
            Background="{DynamicResource MainGradient}"
            BorderBrush="#809AA7B7"
            BorderThickness="1"
            CornerRadius="4">
        <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center">

            <Button x:Name="MachinesButton"
            Click="MachineCatalog_Click"
            Width="40"
            Height="40"
            Padding="2" ToolTip="Machine Catalog"
            Margin="0,0,4,0" Style="{StaticResource MapHotspotButton}">
                <Image Source="/Images/machinebutton.png"
               Width="32"
               Height="32"
               Stretch="Uniform"/>
            </Button>

            <Button Click="MachineInstances_Click"
            Width="40" Style="{StaticResource MapHotspotButton}"
            Height="40"
            Padding="2"
            Margin="0,0,0,0">
                <Image Source="/Images/MachineInstancesButton.png"
               Width="32" ToolTip="Machine Instances"
               Height="32"
               Stretch="Uniform"/>
            </Button>


            <Button x:Name="ProductMaintenanceButton"
 Style="{StaticResource MapHotspotButton}"
 Width="40"  Height="40"  Padding="2"  Margin="4,0,0,0"
 Click="ProductMaintenanceButton_Click">
                <Image Source="/Images/ProductsButton.png"
    Width="32" ToolTip="Product Maintenance"
    Height="32"
    Stretch="Uniform"/>
            </Button>
            <Button x:Name="SettingsButton"
            Style="{StaticResource MapHotspotButton}"
            Width="40"
            Height="40"
            Padding="2"
            Click="SettingsButton_Click">
                <Image Source="/Images/SettingsButton.png"
               Width="32" ToolTip="Settings"
               Height="32"
               Stretch="Uniform"/>
            </Button>

           
        </StackPanel>
    </Border>
</UserControl>
