<UserControl x:Class="CatoriApp.Views.Controls.House.RealEstateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Views.Controls"
             mc:Ignorable="d" Loaded="UserControl_Loaded" x:Name="HouseUC" 
             SizeChanged="HouseControl_SizeChanged" 
             d:DesignHeight="90" d:DesignWidth="90" AllowDrop="True">
        <Border x:Name="MainBorder" BorderThickness="2" Width="{Binding ElementName=HouseUC, Path=ActualWidth}"
            Height="{Binding ElementName=HouseUC, Path=ActualHeight}" >
        <Canvas x:Name="MainLayoutRealestate"  Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
            Height="{Binding ElementName=MainBorder, Path=ActualHeight}" AllowDrop="True" 
                DragDrop.Drop="MainLayout_Drop">
            <Image x:Name="OfficeImage"  Width="{Binding ElementName=MainLayout, Path=ActualWidth}"
            Height="{Binding ElementName=MainLayout, Path=ActualHeight}" MouseDown="OfficeImage_MouseDown"
                   Source="/Images/RealEstateOfficeExterior.png" Stretch="Fill"/>

        </Canvas>
    </Border>
</UserControl>


