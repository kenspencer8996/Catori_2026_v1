<UserControl x:Class="CatoriApp.Views.Controls.House.EntryDoor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Views.Controls.House" x:Name="UC" MouseUp="UserControl_MouseUp">
    <Canvas>
        <Image x:Name="EntryDoorImage"  Stretch="Fill" StretchDirection="Both"  
               Source="/Images/entrytogarage.png" Width="{Binding ElementName=MainBorder, Path=UC}"
            Height="{Binding ElementName=UC, Path=ActualHeight}"  />
    </Canvas>
</UserControl>

