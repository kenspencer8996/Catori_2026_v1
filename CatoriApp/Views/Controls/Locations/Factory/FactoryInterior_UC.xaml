<UserControl
        x:Class="CatoriApp.Views.Controls.Locations.Factory.FactoryInterior_UC"
        x:Name="UC"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Views.Controls.Locations.Factory"
             xmlns:robots="clr-namespace:CatoriApp.Views.Controls.Robots"
             xmlns:uslib="clr-namespace:CatoriUCLibrary.Views.RobotArm;assembly=CatoriUCLibrary"
            xmlns:controls="clr-namespace:CatoriApp.Views.Controls.CommonControls" 
             
             mc:Ignorable="d" Loaded="UserControl_Loaded" MouseDown="UserControl_MouseDown"
             d:DesignHeight="450" d:DesignWidth="800">
    <Viewbox Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Canvas x:Name="MainCanvas" Background="#01FFFFFF" Width="{Binding ActualWidth, ElementName=UC}" 
             Height="{Binding ActualHeight, ElementName=UC}" >
             <Image x:Name="FactoryInteriorImage" Stretch="UniformToFill" 
                Height="{Binding ActualHeight, ElementName=MainCanvas}"
                   Width="{Binding ActualWidth, ElementName=MainCanvas}" Panel.ZIndex="1210"
               Source="/Images/LocationInterior1.png" />
            <Image x:Name="WorkerImage" Stretch="Fill" Source="/Images/GirlStandingRight.png" 
                Height="120" Canvas.Left="64" Canvas.Top="950"/>
            <!--<Image x:Name="RobotBuilderImage" Source="/Images/Left4.png" Canvas.Left="170" Canvas.Top="156" />-->

            <controls:LightPanel x:Name="lightPanel" Canvas.Left="600" Canvas.Top="5" Width="100" Height="100" Panel.ZIndex="1202"/>
            <uslib:RoboticArmUC x:Name="RobotArmNew" Canvas.Left="300" Canvas.Top="200" Width="100" Height="100" Panel.ZIndex="1201"/>
            <robots:RobotControlPanel x:Name="RobotPanel" Canvas.Left="5" Canvas.Top="5" Panel.ZIndex="2000"/>
        </Canvas>
    </Viewbox>
</UserControl>




