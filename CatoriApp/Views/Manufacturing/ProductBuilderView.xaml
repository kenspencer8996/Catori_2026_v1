<Window x:Class="CatoriApp.Views.Manufacturing.ProductBuilderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriApp.Views"
        mc:Ignorable="d"
        Title="Product Builder" WindowState="Maximized">
    <Grid Background="{DynamicResource MainGradient}" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="190"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                Background="#FF88BEFB"
                CornerRadius="16"
                Padding="18"
                Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock Text="🏭 Product Builder"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Label Content="Import:" Margin="300,0,0,0" VerticalAlignment="Center" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <Button x:Name="ProductImport" Content="Product"
                        Width="80" Height="36" Margin="10,0,0,0" Click="ProductImport_Click"/>
                    <Button x:Name="BOMImport" Content="Product"
                        Width="80" Height="36" Margin="10,0,0,0" Click="BOMImport_Click"/>
                    <Button x:Name="ComponentImport" Content="Product"
                        Width="80" Height="36" Margin="10,0,0,0" Click="ComponentImport_Click"/>
                    <Button x:Name="InventoryImport" Content="Product"
                        Width="80" Height="36" Margin="10,0,0,0" Click="InventoryImport_Click"/>
                </StackPanel>
            </DockPanel>
            </Border>

            <!-- Main Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Products List -->
                <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,12,0">

                    <DockPanel>
                        <TextBlock Text="Products"
                               FontSize="20"
                               FontWeight="Bold"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,10"/>

                        <TextBox DockPanel.Dock="Top"
                             Height="32"
                             Margin="0,0,0,10"
                             Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search products"/>

                        <Button x:Name="AddProductButton" Content="+ Add Product"
                            Height="34"
                            DockPanel.Dock="Top"
                            Margin="0,0,0,10" Click="AddProductButton_Click"
                           />

                        <ListBox x:Name="ProductsListBox" SelectionChanged="ProductsListBox_SelectionChanged"
                             SelectedItem="{Binding SelectedProduct}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="0,3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductName}"
                                                   FontWeight="Bold"/>
                                            <TextBlock Text="{Binding ProductCode}"
                                                   Foreground="Gray"
                                                   FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Product Editor -->
                <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="14"
                    Padding="18"
                    Margin="0,0,12,0">

                    <StackPanel>
                        <TextBlock Text="Selected Product"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                        <UniformGrid Columns="2" Rows="5" Margin="0,0,0,18">
                            <TextBlock Text="Name:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NameTextBox"/>

                            <TextBlock Text="Code:" VerticalAlignment="Center"/>
                            <TextBox x:Name="ProductCodeTextBox"/>

                            <TextBlock Text="Type:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ProductTypeListBox" SelectionChanged="ProductTypeListBox_SelectionChanged">
                                <ComboBoxItem Content="Finished"/>
                                <ComboBoxItem Content="Component"/>
                            </ComboBox>

                            <TextBlock Text="Unit:" VerticalAlignment="Center"/>
                            <TextBox x:Name="UnitOfMeasureTextBox"/>

                            <TextBlock Text="Cost:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CostTextBox"/>
                        </UniformGrid>

                        <Button x:Name="SaveProductButton" Content="Save This Product"
                            Height="42"
                            FontSize="16"
                            FontWeight="Bold" Click="SaveProductButton_Click" />

                        <Border Background="#EDF4FF"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,20,0,0">
                            <TextBlock Text="Tip: Finished products are things she can build. Components are parts used in the recipe."
                                   TextWrapping="Wrap"
                                   Foreground="#334"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- BOM Recipe -->
                <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="14"
                    Padding="14">

                    <DockPanel>
                        <TextBlock Text="🧾 BOM Recipe"
                               FontSize="22"
                               FontWeight="Bold"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,10"/>

                        <Button x:Name="AddComponentButton" Content="+ Add Component"
                            Height="34" Click="AddComponentButton_Click"
                            DockPanel.Dock="Top"
                            Margin="0,0,0,10"/>

                        <DataGrid x:Name="BOMDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Component"
                                                Binding="{Binding ComponentName}"
                                                Width="*"/>
                                <DataGridTextColumn Header="Qty"
                                                Binding="{Binding Quantity}"
                                                Width="70"/>
                                <DataGridTextColumn Header="Scrap %"
                                                Binding="{Binding ScrapFactor}"
                                                Width="80"/>
                                <DataGridTextColumn Header="Total"
                                                Binding="{Binding QuantityIncludingScrap}"
                                                Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Inventory Bottom Panel -->
            <Border Grid.Row="2"
                Background="White"
                CornerRadius="14"
                Padding="14"
                Margin="0,12,0,0">

                <DockPanel>
                    <TextBlock Text="📦 Inventory"
                           FontSize="20"
                           FontWeight="Bold"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,10"/>

                    <DataGrid ItemsSource="{Binding SelectedProduct.InventoryItems}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Location"
                                            Binding="{Binding Location}"
                                            Width="*"/>
                            <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding QuantityOnHand}"
                                            Width="140"/>
                            <DataGridTextColumn Header="Last Updated"
                                            Binding="{Binding LastUpdated}"
                                            Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
</Window>


