<Window x:Class="CatoriApp.MachineLayoutDesigner.Views.MachineCatalog.MachineCatalogEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Machine Catalog"
        Height="460" Width="1160"   WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Background="{DynamicResource MainGradient}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="8" Background="{DynamicResource MainGradient}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Button Content="New Machine" Click="NewDefinition_Click" Margin="0,0,0,6" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button Content="Save Machine" Click="SaveDefinition_Click" Margin="0,0,0,6" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button Content="Edit Instances" Click="EditInstances_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Definitions}"
                         SelectedItem="{Binding SelectedDefinition}"
                         DisplayMemberPath="MachineName" />
            </DockPanel>

            <Grid Grid.Column="1">
                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <Label Content="Type" />
                    <ComboBox x:Name="MachineTypeComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Name"
                              SelectionChanged="MachineTypeComboBox_SelectionChanged"
                              SelectedValue="{Binding SelectedDefinition.MachineType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Name" />
                    <TextBox x:Name="MachineNameTextBox" Text="{Binding SelectedDefinition.MachineName, UpdateSourceTrigger=PropertyChanged}" LostFocus="MachineNameTextBox_LostFocusAsync"/>
                    <Label Content="Default Width" />
                    <TextBox Text="{Binding SelectedDefinition.DefaultWidth, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Default Height" />
                    <TextBox Text="{Binding SelectedDefinition.DefaultHeight, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Description" />
                    <TextBox Text="{Binding SelectedDefinition.Description, UpdateSourceTrigger=PropertyChanged}" />
                </UniformGrid>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0" />
    </Grid>
</Window>
