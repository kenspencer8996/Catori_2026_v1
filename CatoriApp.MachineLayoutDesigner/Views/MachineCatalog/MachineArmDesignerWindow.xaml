<Window x:Class="CatoriApp.MachineLayoutDesigner.Views.MachineCatalog.MachineArmDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uslib="clr-namespace:CatoriUCLibrary.Views.RobotArm;assembly=CatoriUCLibrary"
        Title="Machine Arm Designer"
        Height="820"
        Width="1240"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Background="{DynamicResource MainGradient}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White">
            <Viewbox Stretch="Uniform">
                <Canvas Width="800" Height="600">
                    <uslib:RoboticArmUC x:Name="ArmPreview"
                                        Width="800"
                                        Height="600" />
                </Canvas>
            </Viewbox>
        </Border>

        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Machine Instance" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                <UniformGrid Columns="2">
                    <Label Content="Machine Type" />
                    <TextBox Text="{Binding Definition.MachineType, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Machine Name" />
                    <TextBox Text="{Binding Definition.MachineName, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Instance" />
                    <TextBox Text="{Binding Instance.InstanceName, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Display" />
                    <TextBox Text="{Binding Instance.DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                </UniformGrid>
            </StackPanel>

            <TabControl Grid.Row="1" Margin="0,12,0,12">
                <TabItem Header="Parts">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding Instance.Segments}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding SegmentIndex}" Width="42" />
                                <DataGridTextColumn Header="Name" Binding="{Binding SegmentName, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                <DataGridTextColumn Header="Length" Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                <DataGridTextColumn Header="Thick" Binding="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Width="64" />
                                <DataGridTextColumn Header="Angle" Binding="{Binding InitialAngle, UpdateSourceTrigger=PropertyChanged}" Width="64" />
                                <DataGridTextColumn Header="Overlap" Binding="{Binding Overlap, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                <DataGridTextColumn Header="Image" Binding="{Binding ImageName, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Add Part" Click="AddSegment_Click" Margin="0,0,8,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                            <Button Content="Apply To Preview" Click="ApplySegments_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Test Pose">
                    <StackPanel Margin="8">
                        <TextBlock Text="Joint 1" />
                        <Slider Minimum="-180" Maximum="180" Value="{Binding Joint1, UpdateSourceTrigger=PropertyChanged}" ValueChanged="JointSlider_ValueChanged" />
                        <TextBlock Text="{Binding Joint1}" Margin="0,0,0,8" />

                        <TextBlock Text="Joint 2" />
                        <Slider Minimum="-180" Maximum="180" Value="{Binding Joint2, UpdateSourceTrigger=PropertyChanged}" ValueChanged="JointSlider_ValueChanged" />
                        <TextBlock Text="{Binding Joint2}" Margin="0,0,0,8" />

                        <TextBlock Text="Joint 3" />
                        <Slider Minimum="-180" Maximum="180" Value="{Binding Joint3, UpdateSourceTrigger=PropertyChanged}" ValueChanged="JointSlider_ValueChanged" />
                        <TextBlock Text="{Binding Joint3}" Margin="0,0,0,8" />

                        <TextBlock Text="Joint End" />
                        <Slider Minimum="-180" Maximum="180" Value="{Binding JointEnd, UpdateSourceTrigger=PropertyChanged}" ValueChanged="JointSlider_ValueChanged" />
                        <TextBlock Text="{Binding JointEnd}" Margin="0,0,0,8" />

                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <Button Content="Reset Pose" Click="ResetPose_Click" Margin="0,0,4,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                            <Button Content="Capture As Initial" Click="CaptureInitialPose_Click" Margin="4,0,0,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                        </UniformGrid>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2">
                <UniformGrid Columns="3">
                    <Button Content="Save Machine" Click="SaveDefinition_Click" Margin="0,0,4,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button Content="Save Instance" Click="SaveInstance_Click" Margin="4,0,4,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button Content="Close" Click="Close_Click" Margin="4,0,0,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                </UniformGrid>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
