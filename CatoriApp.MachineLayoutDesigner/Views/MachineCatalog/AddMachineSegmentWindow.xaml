<Window x:Class="CatoriApp.MachineLayoutDesigner.Views.MachineCatalog.AddMachineSegmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriApp.MachineLayoutDesigner.Views.MachineCatalog"
        mc:Ignorable="d"
        Title="Edit Machine Segment"
        Width="600"
        Height="460"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource MainGradient}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="Arm Type"/>
                <ComboBox x:Name="ArmTypeComboBox"
                          SelectionChanged="ArmTypeComboBox_SelectionChanged">
                   </ComboBox>

                <Label Content="Color" Margin="0,10,0,0"/>
                <ComboBox x:Name="ArmColorComboBox"
                          SelectionChanged="ArmColorComboBox_SelectionChanged">
                    <ComboBoxItem Content="Blue"/>
                    <ComboBoxItem Content="Red"/>
                    <ComboBoxItem Content="Yellow"/>
                    <ComboBoxItem Content="Steel"/>
                    <ComboBoxItem Content="Black"/>
                </ComboBox>

                <Label Content="Length" Margin="0,10,0,0"/>
                <ComboBox x:Name="ArmLengthComboBox"
                          SelectionChanged="SelectionChanged">
                    <ComboBoxItem Content="80"/>
                    <ComboBoxItem Content="124"/>
                    <ComboBoxItem Content="160"/>
                    <ComboBoxItem Content="220"/>
                </ComboBox>
            </StackPanel>

            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Preview"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <Image x:Name="PreviewImage"
                           Height="520"
                           Stretch="Uniform"/>
       
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="Cancel"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}"/>
            <Button x:Name="AddButton" Content="Add"
                    Width="80" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}"
                    Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
