<Window x:Class="CatoriApp.MachineLayoutDesigner.Views.MachineCatalog.MachineInstanceEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Machine Instances"
        Height="760"
        Width="1160"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Background="{DynamicResource MainGradient}">
    <Window.Resources>
        <x:Array x:Key="SegmentColors" Type="{x:Type sys:String}">
            <sys:String>Red</sys:String>
            <sys:String>Yellow</sys:String>
            <sys:String>Gray</sys:String>
            <sys:String>Blue</sys:String>
        </x:Array>
        <x:Array x:Key="SegmentPartTypes" Type="{x:Type sys:String}">
            <sys:String>long</sys:String>
            <sys:String>medium</sys:String>
            <sys:String>short</sys:String>
            <sys:String>hand</sys:String>
        </x:Array>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Button Content="Save Instance" Click="SaveInstance_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                </StackPanel>
                <ListBox x:Name="InstanceListBox" ItemsSource="{Binding Instances}"
                         SelectedItem="{Binding SelectedInstance}"
                         DisplayMemberPath="InstanceName"
                         SelectionChanged="ListBox_SelectionChanged" />
            </DockPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,8">
                    <Label Content="Machine" />
                    <ComboBox x:Name="MachineComboBox" ItemsSource="{Binding Definitions}"
                              SelectedItem="{Binding SelectedDefinition}" SelectionChanged="MachineComboBox_SelectionChanged"
                              DisplayMemberPath="MachineName" />
                    <Label Content="Instance Name" />
                    <TextBox Text="{Binding SelectedInstance.InstanceName, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Display Name" />
                    <TextBox Text="{Binding SelectedInstance.DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Scale" />
                    <TextBox Text="{Binding SelectedInstance.DefaultScale, UpdateSourceTrigger=PropertyChanged}" />
                </UniformGrid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedInstance.Segments}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding SegmentIndex}" Width="48" />
                        <DataGridTextColumn Header="Name" Binding="{Binding SegmentName, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridTextColumn Header="Length" Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                        <DataGridTextColumn Header="Thick" Binding="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                        <DataGridTextColumn Header="Initial" Binding="{Binding InitialAngle, UpdateSourceTrigger=PropertyChanged}" Width="64" />
                        <DataGridTextColumn Header="Min" Binding="{Binding MinAngle, UpdateSourceTrigger=PropertyChanged}" Width="56" />
                        <DataGridTextColumn Header="Max" Binding="{Binding MaxAngle, UpdateSourceTrigger=PropertyChanged}" Width="56" />
                        <DataGridTextColumn Header="Overlap" Binding="{Binding Overlap, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                        <DataGridTextColumn IsReadOnly="True" Header="Color" Binding="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                        <DataGridTextColumn IsReadOnly="True" Header="Image" Binding="{Binding ImageName, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="New Instance" Click="NewInstance_Click" Margin="0,0,150,0" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button x:Name="EditDesignButton" Content="Edit Design/Test" Click="DesignInstanceArm_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button x:Name="EditCraneButton" Content="Edit Crane/Test" Click="EditCraneButton_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button x:Name="EditDroneRollingButton" Content="Edit Drone/Test" Click="EditDroneRollingButton_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                    <Button x:Name="EditPaintBoothButton" Content="Edit Paint Booth/Test" Click="EditPaintBoothButton_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" />
                </StackPanel>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0" />
    </Grid>
</Window>
