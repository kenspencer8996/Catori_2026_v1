<Window x:Class="CatoriCity2025WPF.Views.RealestateInteriorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriCity2025WPF.Views"
        mc:Ignorable="d" WindowStartupLocation="CenterOwner"
        Title="RealestateInteriorView" Height="1024" Width="1200">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Buy a House" FontSize="24" FontWeight="Bold"/>
            <TextBlock x:Name="OwnerText" Text="Owner: " FontSize="14" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- House Selection -->
        <GroupBox Grid.Row="1" Header="Select House" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <ComboBox x:Name="HouseComboBox" MinWidth="200" Margin="10"  
                          SelectionChanged="HouseComboBox_SelectionChanged" SelectedItem="{Binding SelectedPerson}" >
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <Image Source="{Binding HouseImageFileName}" Width="64" Height="64" Margin="0,0,8,0" Stretch="UniformToFill"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </GroupBox>

        <!-- House Details -->
        <GroupBox Grid.Row="2" Header="House Details" Padding="15">
            <StackPanel>
                <!-- House Image -->
                <Border BorderBrush="LightGray" BorderThickness="2" Height="200" Margin="0,0,0,15">
                    <Image x:Name="HouseImage" Stretch="Uniform"/>
                </Border>

                <!-- House Info -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="House Name:" FontWeight="Bold" Margin="0,0,10,10"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HouseNameText" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" FontWeight="Bold" Margin="0,0,10,10"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StatusText" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Price:" FontWeight="Bold" Margin="0,0,10,10"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CurrentPriceText" Margin="0,0,0,10"/>
                </Grid>

                <!-- Sale Price Input -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Sale Price:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="SalePriceTextBox" 
                             Height="35" 
                             FontSize="16"
                             VerticalContentAlignment="Center"
                             TextChanged="SalePriceTextBox_TextChanged"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="ListForSaleButton"
                            Content="List For Sale"
                            Click="ListForSaleButton_Click"
                            Width="140" Height="40" 
                            FontSize="14" FontWeight="Bold"
                            Background="#4CAF50" Foreground="White"
                            Margin="0,0,10,0"
                            IsEnabled="False"/>

                    <Button x:Name="RemoveFromSaleButton"
                            Content="Remove From Sale"
                            Click="RemoveFromSaleButton_Click"
                            Width="140" Height="40"
                            FontSize="14" FontWeight="Bold"
                            Background="#F44336" Foreground="White"
                            IsEnabled="False"/>
                </StackPanel>

                <!-- Status Message -->
                <TextBlock x:Name="MessageText" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center"
                           Margin="0,15,0,0"
                           FontSize="12"/>
            </StackPanel>
        </GroupBox>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Refresh" Click="RefreshButton_Click" Width="100" Height="35" Margin="0,0,10,0"/>
            <Button Content="Close" Click="CloseButton_Click" Width="100" Height="35"/>
        </StackPanel>
    </Grid>

</Window>
