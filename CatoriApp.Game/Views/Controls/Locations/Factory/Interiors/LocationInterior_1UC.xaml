<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:uslib="clr-namespace:CatoriUCLibrary.Views.RobotArmUC;assembly=CatoriUCLibrary"
             xmlns:local="clr-namespace:CatoriApp.Game.Views.Controls.CommonControls" xmlns:LocationInteriors="clr-namespace:CatoriApp.Game.Views.Controls.Locations.Factory.Interiors" xmlns:CatoriApp="clr-namespace:CatoriApp" xmlns:Robots="clr-namespace:CatoriApp.Game.Views.Controls.Robots" x:Class="CatoriApp.Game.Views.Controls.Locations.Factory.Interiors.LocationInterior_1UC"
             MouseDown="UC_MouseDown" MouseMove="UC_MouseMove"
             mc:Ignorable="d" Width="450" Height="320" x:Name="UC" Loaded="UC_Loaded">
    <Viewbox Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Canvas x:Name="MainCanvas" Background="#01FFFFFF" Width="{Binding ActualWidth, ElementName=UC}" 
             Height="{Binding ActualHeight, ElementName=UC}" Loaded="MainCanvas_Loaded">
            <Image x:Name="Location1InteriorImage" Stretch="UniformToFill" 
                Height="{Binding ActualHeight, ElementName=MainCanvas}"
                   Width="{Binding ActualWidth, ElementName=MainCanvas}"
               Source="/Images/LocationInterior1.png" />
            <Image x:Name="WorkerImage" Stretch="Fill" Source="/Images/GirlStandingRight.png" 
                Height="120" Canvas.Left="64" Canvas.Top="950"/>
            <!--<Image x:Name="RobotBuilderImage" Source="/Images/Left4.png" Canvas.Left="170" Canvas.Top="156" />-->

            <LocationInteriors:RobotControlPanel x:Name="RobotPanel"  Canvas.Left="100" Visibility="Hidden" Canvas.Top="0" Width="300"/>
            <Button x:Name="ExitButton" Style="{StaticResource MapHotspotButton}" Width="50" Height="50" Canvas.Left="5" Canvas.Top="5" 
                Click="ExitButton_Click" ToolTip="Click to exit"  />
            <Label x:Name="RobotConveyorALabel" Content="A" Canvas.Left="200" Canvas.Top="50" Foreground="White" FontSize="24"/>
            <Label x:Name="RobotConveyorBLabel" Content="B" Canvas.Left="200" Canvas.Top="50" Foreground="White" FontSize="24"/>
            <Label x:Name="RobotConveyorCLabel" Content="C: Idle" Canvas.Left="200" Canvas.Top="50" Foreground="White" FontSize="24"/>
            <local:LightPanel x:Name="lightPanel" Canvas.Left="200" Canvas.Top="100" Width="100" Height="100" Panel.ZIndex="1202"/>
            <uslib:RoboticArmUC x:Name="RobotArmNew" Canvas.Left="300" Canvas.Top="200" Width="100" Height="100" Panel.ZIndex="1201"/>
        </Canvas>
    </Viewbox>
</UserControl>




