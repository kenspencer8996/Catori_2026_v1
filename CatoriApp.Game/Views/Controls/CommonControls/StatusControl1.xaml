<UserControl x:Class="CatoriApp.Game.Views.Controls.CommonControls.StatusControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Game.Views.Controls.CommonControls"
             mc:Ignorable="d"  MouseEnter="UserControl_MouseEnter" MouseLeave="UserControl_MouseLeave"
             d:DesignHeight="120" d:DesignWidth="400" Background="{DynamicResource MainGradient}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Content="Status" HorizontalContentAlignment="Center" Foreground="Red"/>
        <Label Grid.Row="1" Grid.Column="0" Content="Name:"/>
        <Label Grid.Row="1" Grid.Column="1" x:Name="NameLabel" x:FieldModifier="public"  />
        <Label Grid.Row="2" Grid.Column="0" Content="Current Funds:"/>
        <Label Grid.Row="2" Grid.Column="1" x:Name="FundsLabel" x:FieldModifier="public" Content="{Binding Funds, Mode=TwoWay}" />
        <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding StatusMessage, Mode=TwoWay}" />

    </Grid>
</UserControl>



