<UserControl x:Class="CatoriApp.Game.Views.Controls.DroneDeliver1UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Game.Views.Controls"
             mc:Ignorable="d" x:Name="UC" Width="128" Height="128" >
    <Border x:Name="MainBorder" Canvas.Left="0" Canvas.Top="0" BorderThickness="4" BorderBrush="#FFF11111" 
             Width="{Binding ElementName=UC, Path=ActualWidth}" 
            Height="{Binding ElementName=UC, Path=ActualHeight}" >
        <Canvas>
            <Image x:Name="DroneImage"
                Width="{Binding ElementName=MainBorder, Path=ActualWidth}" 
                 Height="{Binding ElementName=MainBorder, Path=ActualHeight}"
              Canvas.Left="0"
              Canvas.Top="0"
              Stretch="Uniform"
              SnapsToDevicePixels="True" Source="/Images/DroneWithBox.png"/>

        </Canvas>
    </Border>
</UserControl>

