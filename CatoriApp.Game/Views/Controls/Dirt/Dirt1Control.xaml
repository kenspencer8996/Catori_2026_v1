<UserControl x:Class="CatoriApp.Game.Views.Controls.Dirt.Dirt1Control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Game.Views.Controls.Dirt"
             mc:Ignorable="d" MouseEnter="UserControl_MouseEnter" MouseUp="UserControl_MouseUp"
            Width="800" Height="450" x:Name="UC">
    <Grid x:Name="MainLayoutDirt" Width="{Binding ElementName=UC, Path=ActualWidth}" 
             Height="{Binding ElementName=UC, Path=ActualHeight}">
        <Image x:Name="Dirt1Image"  Stretch="Fill" StretchDirection="Both"  
               Source="/Images/Dirt1.png" Width="{Binding ElementName=MainLayout, Path=ActualWidth}" 
             Height="{Binding ElementName=MainLayout, Path=ActualHeight}"/>
    </Grid>
</UserControl>

