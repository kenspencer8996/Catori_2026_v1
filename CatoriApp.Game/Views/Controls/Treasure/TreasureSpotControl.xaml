<UserControl x:Class="CatoriApp.Game.Views.Controls.Treasure.TreasureSpotControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Game.Views.Controls.Treasure" Loaded="UC_Loaded"
             mc:Ignorable="d" x:Name="UC" Width="200" Height="65" Background="Transparent" >
    <Border x:Name="GlowBorder" Background="Transparent" >
        <Canvas x:Name="MainLayoutTreasureSpot" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" MouseMove="MainLayoutTreasureSpot_MouseMove">
        <Image x:Name="TreasureSpotImage" Stretch="Fill" StretchDirection="Both"  Width="{Binding ActualWidth, ElementName=MainLayoutTreasureSpot}"
                   Height="{Binding ActualHeight, ElementName=MainLayoutTreasureSpot}" Source="/Images/DirtSpot.png" Panel.ZIndex="200" Canvas.Left="0" Canvas.Top="0" Margin="0,0,0,0" />
            <Label x:Name="DebugLabel" Content="Debug" FontSize="16" Panel.ZIndex="1020" Foreground="#FFF9F9F9" Background="#FFFD0707"  MouseDown="DebugLabel_MouseDown"/>
        </Canvas>
    </Border>
</UserControl>

