<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriApp.Game.Views" xmlns:Treasure="clr-namespace:CatoriApp.Game.Views.Controls.Treasure" xmlns:Controls="clr-namespace:CatoriApp.Game.Views.Controls" x:Class="CatoriApp.Game.Views.Treasure.TreasureFieldView"
        WindowStyle="None" MouseMove="TreasureField1View_MouseMove"
        mc:Ignorable="d" x:Name="TreasureField1View" WindowStartupLocation="CenterOwner"
        Title="TreasureFile1View" WindowState="Maximized"  Loaded="TreasureField1View_Loaded">
    <Viewbox Stretch="Fill" StretchDirection="Both">
        <Grid x:Name="MainLayout" Width="1920" Height="1080">
            <Canvas x:Name="MainLayoutField"  Width="{Binding ActualWidth, ElementName=TreasureField1View}"
                Height="{Binding ActualHeight, ElementName=TreasureField1View}">
                <Image x:Name="FieldImage" Source="/Images/FieldEmpty3D.png" Stretch="Fill" StretchDirection="Both"  Width="{Binding ActualWidth, ElementName=MainLayout}"
        Height="{Binding ActualHeight, ElementName=MainLayout}"  />
                <Button x:Name="ExitButton" Style="{StaticResource MapHotspotButton}" Width="50" Height="50" Canvas.Left="1872" Canvas.Top="5" 
           Click="ExitButton_Click" ToolTip="Click to exit"  />
                <Button x:Name="ShowStepsButton" Style="{StaticResource MapHotspotButton}" Width="50" Height="50" Canvas.Left="60" Canvas.Top="5" Click="ShowStepsButton_Click" ToolTip="Show learned steps panel">
                    <Image Source="/Images/LearnedStepsButton.png" Stretch="Uniform"/>
                </Button>
                <Treasure:TreasureWorkBench x:Name="workbench" Canvas.Left="1434" Canvas.Top="598" Panel.ZIndex="1100"/>
             </Canvas>
        </Grid>
    </Viewbox>
</Window>


