<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriApp.Game.Views"
        xmlns:House="clr-namespace:CatoriApp.Game.Views.Controls.House" x:Class="CatoriApp.Game.Views.House.DetailHouseInsideView"
        mc:Ignorable="d" Loaded="Window_Loaded"
        Title="DetailHouseInsideView" Height="800" Width="1000" WindowStartupLocation="CenterOwner" WindowStyle="None">
    <Canvas x:Name="MainLayoutDetailHome" Width="{Binding ActualWidth, ElementName=DetailHouseInsideView}" 
             Height="{Binding ActualHeight, ElementName=DetailHouseInsideView}" Background="White">
        <Image x:Name="MainImage" Stretch="Fill"  Canvas.Left="30" />
        <Button x:Name="ShrinkButton" Width="15" Height="15" Click="ShrinkButton_Click" Canvas.Left="985">
            <Image Source="/Images/closexred.png"/>
        </Button>
        <Label Content="$"  Canvas.Left="0" Canvas.Top="20" />
        <TextBox x:Name="FundsLabel" Text="{Binding Funds.Money}" IsReadOnly="True" 
                 Canvas.Left="5" Canvas.Top="20" MouseDown="FundsLabel_MouseDown" MouseMove="FundsLabel_MouseMove" GiveFeedback="FundsLabel_GiveFeedback" />
        <Image x:Name="PersonImage" Canvas.Left="40" Canvas.Top="100"/>
        <House:EntryDoor x:Name="EntryDoorToGarage"  Panel.ZIndex="3000" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </Canvas>
</Window>


