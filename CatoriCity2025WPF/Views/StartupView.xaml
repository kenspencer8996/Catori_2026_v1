<Window x:Class="CatoriCity2025WPF.Views.StartupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriCity2025WPF.Views"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen" WindowState="Normal"
        Title="StartupView"  Height="1080" Width="1920">
    <Canvas>
        <Image Source="/Images/StartWorld.png" Stretch="Fill" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Center" Canvas.Top="1" VerticalAlignment="Top" />
        <Button x:Name="CityScapeButton" Style="{StaticResource MapHotspotButton}" Width="355" Height="280" Canvas.Left="750" Canvas.Top="253" 
                Click="CityScapeButton_Click" ToolTip="Click to open CityScape"  />
        <Button x:Name="TreasureHuntButton" Style="{StaticResource MapHotspotButton}" Width="355" Height="280" 
                Canvas.Left="750" Canvas.Top="553" 
            Click="TreasureHuntButton_Click" ToolTip="Click to open TreasureHunt"  />
        <Button x:Name="ExitButton" Style="{StaticResource MapHotspotButton}" Width="50" Height="50" Canvas.Left="5" Canvas.Top="5" 
                Click="ExitButton_Click" ToolTip="Click to exit"  />


    </Canvas>
</Window>
