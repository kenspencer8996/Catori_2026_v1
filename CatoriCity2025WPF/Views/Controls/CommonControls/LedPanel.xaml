<UserControl x:Class="CatoriCity2025WPF.LedPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF"
             mc:Ignorable="d" x:Name="UC"
             d:DesignHeight="450" d:DesignWidth="800" >

    <Border Padding="6" CornerRadius="6" Background="#1E1E1E" Width="{Binding ActualWidth, ElementName=UC}"
         Height="{Binding ActualHeight, ElementName=UC}">
        <ItemsControl ItemsSource="{Binding Lights, ElementName=root}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Ellipse Width="18"
                             Height="18"
                             Margin="4"
                             Fill="{Binding CurrentBrush}"
                             Stroke="#555"
                             StrokeThickness="1"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>
    </Border>
</UserControl>
