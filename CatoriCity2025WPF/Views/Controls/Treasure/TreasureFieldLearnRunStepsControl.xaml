<UserControl x:Class="CatoriCity2025WPF.Views.Controls.Treasure.TreasureFieldLearnRunStepsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls.Treasure"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="320">
    <Grid  Background="{DynamicResource MainGradient}">
        <Grid.ColumnDefinitions>
             <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Main play area -->

        <!-- Learn panel -->
        <Border Grid.Column="0"
            Margin="10"
            Padding="12"
            CornerRadius="10"
             BorderBrush="#AA9988"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Learn Mode" FontSize="22"
                       FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1">
                    <CheckBox x:Name="SelectAllCheckBox" VerticalAlignment="Center"
                      Content="Select All" Margin="20,0,0,0" Checked="SelectAllCheckBox_Checked"/>
                </StackPanel>
                <GroupBox Grid.Row="2" Header="Current Steps" Margin="0,0,0,10">
                    <ListBox x:Name="RecordedStepsListbox" ItemsSource="{Binding LearnedSteps}" MinHeight="100" SelectionChanged="RecordedStepsListbox_SelectionChanged"
                         SelectedItem="{Binding SelectedStep}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding StepNumber}"
                                           Width="28"
                                           FontWeight="Bold"/>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <WrapPanel>
                        <Button Content="Run Step" x:Name="RunStepButton" Click="RunStepButton_Click" Width="90" Margin="4"/>
                        <Button Content="Run All" x:Name="RunAllButton" Click="RunAllButton_Click" Width="90" Margin="4"/>
                        <Button Content="Save" x:Name="SaveButton" Width="70" Margin="4" Click="SaveButton_Click" />
                        <Button Content="Remove" x:Name="RemoveButton" Click="RemoveButton_Click" Width="70" Margin="4"/>
                        <TextBox x:Name="numberOfSpotsToRunTextbox" MinWidth="50" Text="0" VerticalAlignment="Center" />
                        <Label Content="running:" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <Label x:Name="RunningCountLabel" Content="0" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </WrapPanel>
                </StackPanel>

                <GroupBox Grid.Row="4" Header="Money from treasure">
                    <StackPanel Margin="6">
                        <TextBlock Text="{Binding CashDisplay}" Margin="0,2"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
