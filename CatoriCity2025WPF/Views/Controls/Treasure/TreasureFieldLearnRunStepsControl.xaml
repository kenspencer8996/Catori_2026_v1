<UserControl x:Class="CatoriCity2025WPF.Views.Controls.Treasure.TreasureFieldLearnRunStepsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls.Treasure"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="320">
    <Grid  Background="{DynamicResource MainGradient}">
        <Grid.ColumnDefinitions>
             <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Main play area -->

        <!-- Learn panel -->
        <Border Grid.Column="0"
            Margin="10"
            Padding="12"
            CornerRadius="10"
             BorderBrush="#AA9988"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Learn Mode"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

                <CheckBox Grid.Row="1"
                      Content="Auto Run"
                      IsChecked="{Binding IsAutoRunEnabled}"
                      Margin="0,0,0,10"/>

                <GroupBox Grid.Row="2" Header="Current Steps" Margin="0,0,0,10">
                    <ListBox ItemsSource="{Binding LearnedSteps}"
                         SelectedItem="{Binding SelectedStep}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding StepNumber}"
                                           Width="28"
                                           FontWeight="Bold"/>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <WrapPanel>
                        <Button Content="Run Step" Width="90" Margin="4"/>
                        <Button Content="Run All" Width="90" Margin="4"/>
                        <Button Content="Add" Width="70" Margin="4"/>
                        <Button Content="Remove" Width="70" Margin="4"/>
                        <Button Content="Clear" Width="70" Margin="4"/>
                    </WrapPanel>
                </StackPanel>

                <GroupBox Grid.Row="4" Header="Money">
                    <StackPanel Margin="6">
                        <TextBlock Text="{Binding CashDisplay}" Margin="0,2"/>
                        <TextBlock Text="{Binding SavingsDisplay}" Margin="0,2"/>
                        <TextBlock Text="{Binding InterestDisplay}" Margin="0,2"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
