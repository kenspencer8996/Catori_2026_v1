<UserControl x:Class="CatoriCity2025WPF.Views.Controls.LightPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls"
             mc:Ignorable="d" MouseRightButtonDown="UserControl_MouseRightButtonDown" 
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown" Width="106" Height="56">
 
    <Border BorderThickness="2" BorderBrush="Gray" Background="Gray">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
            <Ellipse x:Name="Light1" 
                Width="50"
                Height="50"
                Fill="Blue"
                Stroke="Black"
                StrokeThickness="4"
                Canvas.Left="100"
                Canvas.Top="20" />
            <Ellipse x:Name="Light2"
                Width="50"
                Height="50"
                Fill="Blue"
                Stroke="Black"
                StrokeThickness="4"
                Canvas.Left="100"
                Canvas.Top="20" />
        </StackPanel>
    </Border>
</UserControl>
