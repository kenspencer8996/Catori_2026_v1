<UserControl x:Class="CatoriCity2025WPF.Views.Controls.PersonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls" MouseUp="UserControl_MouseUp"
             mc:Ignorable="d" >
    <Border x:Name="MainBorder" BorderBrush="Black" >
        <Canvas>
            <Canvas.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="DepositMenu" Header="Deposit Funds" Click="DepositMenu_Click"/>
                </ContextMenu>
            </Canvas.ContextMenu>
            <Image x:Name="PersonImage" Width="80" Height="200" Source="/Images/GirlWalkLeft01.png" />
        </Canvas>
    </Border>
</UserControl>
