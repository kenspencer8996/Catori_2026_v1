<UserControl x:Class="CatoriApp.Views.Controls.Robots.RobotControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Views.Controls.Factory"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border CornerRadius="12"
            BorderBrush="#555"
            BorderThickness="2"
            Background="{DynamicResource MainGradient}"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="RobotNameTextBlock"
                       Grid.Row="0"
                       Text="Assembly Robot"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="2" >
                <TextBlock Text="Input A" FontWeight="SemiBold"/>
                <ComboBox x:Name="InputAComboBox" Margin="0,4,0,0" SelectionChanged="InputAComboBox_SelectionChanged" />
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Input B" FontWeight="SemiBold"/>
                <ComboBox x:Name="InputBComboBox" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="6">
                <TextBlock Text="Output Destination" FontWeight="SemiBold"/>
                <ComboBox x:Name="OutputComboBox" Margin="0,4,0,0"/>
            </StackPanel>

           
            <UniformGrid Grid.Row="10" Columns="3" Margin="0,6,0,0">
                <Button x:Name="RunButton"
                        Content="Run"
                        Margin="4"
                        Padding="8"
                        Click="RunButton_Click_1" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}"/>

                <!--<Button x:Name="TeachButton"
                        Content="Teach"
                        Margin="4"
                        Padding="8"
                        Click="TeachButton_Click"/>-->
                <Button x:Name="DesignModeButton"
          Content="Edit Mode"
                  Margin="4"
                  Padding="8"  Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}"
                  Click="DesignModeButton_Click"/>
                <Button x:Name="RobotDesignButton"
      Content="Robot Design"
              Margin="4"
              Padding="8"  Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}"
              Click="RobotDesignButton_Click"/>
            </UniformGrid>

            <StackPanel Grid.Row="12">
                <TextBlock Text="Status" FontWeight="SemiBold"/>
                <Border Margin="0,4,0,0"
                        Padding="8"
                        Background="White"
                        BorderBrush="#AAA"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Idle"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

