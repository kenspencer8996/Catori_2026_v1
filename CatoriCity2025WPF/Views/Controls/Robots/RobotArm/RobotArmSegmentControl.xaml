<UserControl x:Class="CatoriCity2025WPF.Views.Controls.Robots.RobotArm.RobotArmSegmentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="140"
             Height="40" ClipToBounds="False"
             MouseDown="UserControl_MouseDown"
             RenderTransformOrigin="0,0.5">

    <UserControl.RenderTransform>
        <RotateTransform x:Name="SegmentRotate" Angle="-90"/>
    </UserControl.RenderTransform>
    <Border BorderThickness="1" BorderBrush="Black">
    <Image x:Name="SegmentImage"
           Width="140"
           Height="30" 
           Stretch="UniformToFill"
           Source="/Images/robotArmLongBlue.png"/>
    </Border>
</UserControl>