<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls.Robots.RobotArm"
            x:Class="CatoriCity2025WPF.Views.Controls.Robots.RobotArm.RobotArmControl"
             mc:Ignorable="d" MouseMove="UserControl_MouseMove"
             d:DesignHeight="450" MouseDown="UserControl_MouseDown" MouseUp="UserControl_MouseUp"
             d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Viewbox Stretch="Uniform">
        <Canvas x:Name="RobotRoot" Width="800" Height="600" Background="White">

            <!--<Image x:Name="RobotBaseImage"
                    Canvas.Left="0"
                    Canvas.Top="0"
                    Width="80"
                    Height="80"
                    />-->
            <Image x:Name="robotArmBase"  Canvas.Left="355" Canvas.Top="544" Width="80" Source="/Images/RobotBaseBlue.png"/>
            <local:RobotArmSegmentControl x:Name="RobotArmSeg1" Canvas.Left="400" Canvas.Top="534" />
            <local:RobotArmSegmentControl x:Name="RobotArmSeg2" Canvas.Left="400" Canvas.Top="408"/>
            <local:RobotArmSegmentControl x:Name="RobotArmSeg3" Canvas.Left="400" Canvas.Top="268"/>
            <local:RobotArmSegmentControl x:Name="RobotArmSeg4" Canvas.Left="400" Canvas.Top="144"/>
        </Canvas>
    </Viewbox>
</UserControl>