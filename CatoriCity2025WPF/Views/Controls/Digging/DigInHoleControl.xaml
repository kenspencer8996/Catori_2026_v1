<UserControl xmlns:Treasure="clr-namespace:CatoriCity2025WPF.Views.Controls.Treasure"  
             xmlns:Dirt="clr-namespace:CatoriCity2025WPF.Views.Controls.Dirt" 
             x:Class="CatoriCity2025WPF.Views.Controls.Digging.DigInHoleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls.Digging"
             xmlns:drag="clr-namespace:CatoriCity2025WPF.Objects.DragDrop"
             mc:Ignorable="d" Width="240" Height="150" x:Name="UC" >
    <Border x:Name="MainBorder" Background="Transparent" BorderThickness="0" BorderBrush="Black" 
            Width="{Binding ActualWidth, ElementName=UC}"
                   Height="{Binding ActualHeight, ElementName=UC}">
        <Canvas x:Name="MainLayoutForTreasure" Width="{Binding ActualWidth, ElementName=MainBorder}"
                   Height="{Binding ActualHeight, ElementName=MainBorder}">
            <Treasure:TreasureSpotControl x:Name="SpotControl" Width="180" Height="50"
                                          Canvas.Left="0" Canvas.Top="120" />

        </Canvas>
    </Border>
</UserControl>
