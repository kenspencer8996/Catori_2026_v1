<UserControl x:Class="CatoriCity2025WPF.Views.Controls.POSUI_UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls" x:Name="UC"
             mc:Ignorable="d" MinWidth="300" MinHeight="200">
    <Grid x:Name="MainLayout" Background="{DynamicResource MainGradient}" Width="{Binding ElementName=UC, Path=ActualWidth}" 
            Height="{Binding ElementName=UC, Path=ActualHeight}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="200" Width="70*"/>
            <ColumnDefinition Width="30*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="CartDataGrid" Grid.ColumnSpan="2"  Width="{Binding ElementName=MainLayout, Path=ActualWidth}" 
            Height="{Binding ElementName=MainLayout, Path=ActualHeight}" 
                ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=UserControl}}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="True"
                IsReadOnly="False"
                RowHeaderWidth="0"
                SelectionMode="Single"
                Background="{x:Null}" Grid.Row="0">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Picture" MinWidth="40" Width="60" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ShopItem.FilePathAbsolute}" 
                                 Width="50" 
                                 Height="50" 
                                 Stretch="Uniform"
                                 SnapsToDevicePixels="True"
                                 Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Item" Binding="{Binding ShopItem.Name}" IsReadOnly="True" MinWidth="150" Width="5*" />
                <DataGridTextColumn Header="Price" Binding="{Binding ShopItem.Price, StringFormat=C}" MinWidth="100" IsReadOnly="True" Width="1*" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" >
            <Label Content="Total:" VerticalAlignment="Center" Foreground="{DynamicResource ButtonForeground}"/>
            <TextBox x:Name="TotalTextBox" Width="100" Margin="6,0,0,0" VerticalAlignment="Center" IsReadOnly="True"
                     Text="{Binding TotalAmount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat=C}"/>
        </StackPanel>
        <Button x:Name="CheckoutButton" Grid.Row="1" Grid.Column="1" Content="Checkout" Width="100" Height="25" HorizontalAlignment="Right" Margin="0,5,10,5" Click="CheckoutButton_Click"  Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}"/>
    </Grid>
</UserControl>
