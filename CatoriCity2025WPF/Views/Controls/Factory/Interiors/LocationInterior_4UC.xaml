<UserControl x:Class="CatoriApp.Views.Controls.LocationInterior_4UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriApp.Views.Controls"
             mc:Ignorable="d" Width="200" Height="120"
             d:DesignHeight="100" d:DesignWidth="250" x:Name="UC">
    <Viewbox Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Canvas x:Name="MainCanvas" Width="{Binding ElementName=UC, Path=ActualWidth}" 
             Height="{Binding ElementName=UC, Path=ActualHeight}">
            <Image x:Name="Location1InteriorImage" Stretch="UniformToFill" Source="/Images/LocationTables1.png"
                            Height="{Binding ActualHeight, ElementName=MainCanvas}"
                Width="{Binding ActualWidth, ElementName=MainCanvas}"/>
            <local:RobotUC x:Name="RobotLeftUC" HorizontalAlignment="Left" Canvas.Left="324" Canvas.Top="95" VerticalAlignment="Top" Width="50" Height="80"/>
            <local:RobotUC x:Name="RobotRightUC" HorizontalAlignment="Left" Canvas.Left="250" Canvas.Top="102"  VerticalAlignment="Top" Width="24" Height="56"/>
            <Image x:Name="WorkerImage" Stretch="Fill" Source="/Images/GirlStanding.png" 
               Height="140"  Canvas.Left="604" Canvas.Top="515"/>
        </Canvas>
    </Viewbox>
</UserControl>

