<UserControl
    x:Class="CatoriCity2025WPF.Views.Controls.FactoryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    x:Name="FactoryUC"
    Loaded="UserControl_Loaded"
    SizeChanged="UserControl_SizeChanged"
    AllowDrop="False"
    MouseEnter="FactoryControl_MouseEnter"
    MouseLeave="FactoryControl_MouseLeave"
    MouseUp="FactoryControl_MouseUp"
    d:DesignWidth="80"
    d:DesignHeight="80">

    <Border x:Name="MainBorder"
            Background="Transparent"
            BorderThickness="2"
            BorderBrush="Transparent">

        <Canvas x:Name="MainLayoutFactory"
                IsHitTestVisible="False">

            <!-- Factory building image -->
            <Image x:Name="BusinessImage"
                   Canvas.Left="0"
                   Canvas.Top="0"
                   Stretch="Fill"
                   IsHitTestVisible="False"
                   Width="{Binding ActualWidth, ElementName=MainBorder}"
                   Height="{Binding ActualHeight, ElementName=MainBorder}" />

            <!-- Person icon -->
            <Image x:Name="PersonImage"
                   Width="25"
                   Height="25"
                   Canvas.Left="65"
                   Canvas.Top="0"
                   IsHitTestVisible="False" />

            <!-- Gears icon -->
            <Image x:Name="GearsImage"
                   Width="10"
                   Height="10"
                   Canvas.Left="65"
                   Canvas.Top="25"
                   IsHitTestVisible="False" />

        </Canvas>
    </Border>
</UserControl>
