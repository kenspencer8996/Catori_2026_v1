<UserControl x:Class="CatoriCity2025WPF.Views.Controls.GrassWithBareTreasureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls"
             mc:Ignorable="d" x:Name="UC" Width="300" Height="320">
    <Canvas x:Name="MainLayout" Width="{Binding ElementName=UC, Path=ActualWidth}" 
          Height="{Binding ElementName=UC, Path=ActualHeight}" MouseEnter="MainLayout_MouseEnter">
        <Image x:Name="Factory1InteriorImage" Source="/Images/GirlfWithBushesNohole.png" Width="{Binding ElementName=MainLayout, Path=ActualWidth}" 
             Height="{Binding ElementName=MainLayout, Path=ActualHeight}"
               Stretch="UniformToFill"/>
    </Canvas>
</UserControl>
