<Window x:Class="CatoriCity2025WPF.Views.TreasureFieldView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriCity2025WPF.Views"
        mc:Ignorable="d" x:Name="TreasureField1View" WindowStartupLocation="CenterOwner"
        Title="TreasureFile1View" Height="450" Width="800" Loaded="TreasureField1View_Loaded">
    <Canvas x:Name="MainLayoutField"  Width="{Binding ElementName=TreasureField1View, Path=ActualWidth}"
        Height="{Binding ElementName=TreasureField1View, Path=ActualHeight}">
        <Image x:Name="FieldImage" Source="/Images/GirlfWithBushesNohole.png" Stretch="Fill" StretchDirection="Both"  Width="{Binding ElementName=MainLayout, Path=ActualWidth}"
        Height="{Binding ElementName=MainLayout, Path=ActualHeight}"  />
    </Canvas>
</Window>
