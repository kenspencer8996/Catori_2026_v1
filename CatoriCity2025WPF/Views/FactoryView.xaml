<Window x:Class="CatoriCity2025WPF.Views.FactoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriCity2025WPF.Views"
        mc:Ignorable="d" WindowState="Maximized" WindowStyle="None" Loaded="Window_Loaded"
        Title="FactoryView" Height="450" Width="800">
    <Canvas x:Name="MainLayout">
        <Button x:Name="ExitButton" Style="{StaticResource MapHotspotButton}" Width="50" Height="50" Canvas.Left="5" Canvas.Top="5" 
          Click="ExitButton_Click" ToolTip="Click to exit" Panel.ZIndex="10002" />
        <StackPanel x:Name="FactoryUCPanel" Canvas.Left="10" Canvas.Top="0" Panel.ZIndex="900" Orientation="Horizontal"/>
    </Canvas>
</Window>
