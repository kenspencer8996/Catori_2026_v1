<Window x:Class="CatoriCity2025WPF.Views.StoreHardwareInteriorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatoriCity2025WPF.Views.Controls"
        xmlns:Controls="clr-namespace:CatoriCity2025WPF.Views.Controls" 
        mc:Ignorable="d"  WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded" Closing="Window_Closing"
        Title="StoreHardwareView" Height="1080" Width="1620">
    <Border x:Name="MainBorder" Canvas.Left="0" Canvas.Top="0" BorderThickness="0" BorderBrush="#FFF11111" 
          Width="{Binding ElementName=UC, Path=ActualWidth}" 
         Height="{Binding ElementName=UC, Path=ActualHeight}" >
        <Canvas x:Name="MainLayoutHardwareStoreInterior" MouseDown="MainLayout_MouseDown" MouseUp="MainLayout_MouseUp" MouseMove="MainLayout_MouseMove" Width="{Binding ElementName=MainBorder, Path=ActualWidth}" 
         Height="{Binding ElementName=MainBorder, Path=ActualHeight}">
            <Image x:Name="StoreInteriorImage" Stretch="Fill" Source="/Images/Store_hardware_Interior.png" Width="{Binding ElementName=UC, Path=ActualWidth}" 
         Height="{Binding ElementName=MainBorder, Path=ActualHeight}" Panel.ZIndex="2"/>
            <!--<local:RobotCartControl x:Name="robotMover" Canvas.Left="32" Canvas.Top="149" Panel.ZIndex="2000"/>-->
            <local:POSUI_UC x:Name="POSUC" Canvas.Left="700" Canvas.Top="410" Width="320" Height="150" Panel.ZIndex="2500"/>
