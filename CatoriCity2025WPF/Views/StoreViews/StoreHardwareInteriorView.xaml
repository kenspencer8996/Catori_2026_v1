            <!--<Image x:Name="TrapazoidImage" Source="/Images/DronePortal.png" Panel.ZIndex="3001" 
               Canvas.Left="1630" Canvas.Top="70" Width="250" Height="120" Visibility="Hidden" IsEnabled="False"/>-->
            <Image x:Name="DragImage" Source="/Images/gear_.png" Panel.ZIndex="3001" 
    Canvas.Left="500" Canvas.Top="200" Width="250" Height="150" Visibility="Visible"/>
